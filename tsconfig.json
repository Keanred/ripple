{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "esnext",
    "module": "esnext",
    "rootDirs": ["./server", "./client"],
    "outDir": "./dist",
    "strict": true,
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "server/**/*.ts",
    "server/**/*.tsx",
    "server/**/*.mts",
    "server/**/*.cts",
    "client/**/*.ts",
    "client/**/*.tsx",
    "client/**/*.mts",
    "client/**/*.cts"
  ],
  "exclude": ["node_modules", "dist"]
}